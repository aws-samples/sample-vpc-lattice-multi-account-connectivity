                    <mxGeometry relative="1" as="geometry"/>
                </mxCell>
                <mxCell id="23" value="3" style="ellipse;whiteSpace=wrap;html=1;fillColor=#2E73B8;strokeColor=none;fontColor=#FFFFFF;fontStyle=1;fontSize=14;" vertex="1" parent="1">
